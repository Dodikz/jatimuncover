---
export interface Props {
  name: string;
  count?: string;
  image: string;
  isOthers?: boolean;
}

const { name, count, image, isOthers = false } = Astro.props;
---

<div class="relative w-full aspect-[4/3] sm:aspect-auto sm:h-56 rounded-[2rem] overflow-hidden group cursor-pointer hover:-translate-y-2 transition-all duration-300 hover:shadow-xl">
    <img 
        src={image} 
        alt={name} 
        class={`absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ${isOthers ? 'blur-[1px] group-hover:blur-0' : ''}`} 
    />
    <div class={`absolute inset-0 ${isOthers ? 'bg-black/60 group-hover:bg-black/70' : 'bg-black/40 group-hover:bg-black/55'} transition-all duration-500`}></div>
    <div class="absolute inset-0 flex flex-col items-center justify-center p-6 text-center z-10">
        <h3 class="font-display font-bold text-[1.5rem] md:text-[1.8rem] text-white leading-tight drop-shadow-lg group-hover:scale-105 transition-transform duration-500">
            {name}
        </h3>
        
        <div class="mt-6 flex flex-col items-center gap-3 overflow-hidden">
            <div class={`w-8 h-[1px] ${isOthers ? 'bg-green-400' : 'bg-white/30'} group-hover:w-16 group-hover:bg-green-400 transition-all duration-700`}></div>
            <p class="text-white/80 text-[10px] font-bold uppercase tracking-[0.3em] group-hover:text-white group-hover:tracking-[0.4em] transition-all duration-500">
                {isOthers ? 'Lihat Semua' : `${count} Destinasi`}
            </p>
        </div>
    </div>
</div>