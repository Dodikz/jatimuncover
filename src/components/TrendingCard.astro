---
export interface Props {
  title: string;
  location: string;
  rating: string;
  ratingText: string;
  price: string;
  image: string;
}

const { title, location, rating, ratingText, price, image } = Astro.props;
---

<div class="bg-white p-3 rounded-[2rem] border-3 border-transparent hover:border-green-700 hover:shadow-xl flex flex-col hover:-translate-y-2 transition-all duration-300 cursor-pointer">
    <img src={image} alt={location} class="w-full aspect-[4/5] object-cover rounded-[1.5rem]" />
    <div class="pt-4 px-2 pb-2 flex flex-col flex-grow">
        <h3 class="font-bold text-[1.05rem] text-slate-800 leading-snug mb-3">{title}</h3>
        
        <div class="flex items-center gap-1.5 mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-[18px] h-[18px] text-green-800">
                <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
            </svg>
            <span class="text-green-800 font-medium text-sm">{location}</span>
        </div>

        <div class="flex items-center justify-between mt-auto">
            <div class="flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-orange-400">
                    <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" />
                </svg>
                <span class="text-[0.85rem] font-bold text-slate-800">{rating} <span class="font-medium text-slate-500">{ratingText}</span></span>
            </div>
            <span class="text-green-600 font-bold text-[1.1rem]">{price}</span>
        </div>
    </div>
</div>
