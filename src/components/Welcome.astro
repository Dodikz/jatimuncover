---
const videoSources = [
  "https://www.pexels.com/download/video/35122264/",
  "https://www.pexels.com/download/video/18598477/",
  "https://www.pexels.com/download/video/4237849/",
  "https://www.pexels.com/download/video/33084488/",
];
---

<section class="relative h-screen w-full overflow-hidden bg-black">
  <video 
    id="video-1"
    autoplay 
    muted 
    playsinline 
    class="absolute top-0 left-0 w-full h-full object-cover transition-opacity duration-1000 opacity-100"
  >
    <source src={videoSources[0]} type="video/mp4" />
  </video>
  
  <video 
    id="video-2"
    muted 
    playsinline 
    class="absolute top-0 left-0 w-full h-full object-cover transition-opacity duration-1000 opacity-0"
  ></video>

  <div class="absolute inset-0 bg-black/40"></div>

  <div class="relative z-10 flex flex-col items-center justify-center h-full px-4 text-center">
    <div class="animate-pulse">
        <div class="w-1 h-12 bg-white/40 rounded-full shadow-[0_0_20px_rgba(255,255,255,0.3)]"></div>
    </div>
  </div>
</section>

<script define:vars={{ videoSources }}>
  let v1 = document.getElementById('video-1');
  let v2 = document.getElementById('video-2');
  let currentIdx = 0;
  let activeVideo = v1;
  let idleVideo = v2;

  idleVideo.src = videoSources[(currentIdx + 1) % videoSources.length];
  idleVideo.load();

  setInterval(() => {
    currentIdx = (currentIdx + 1) % videoSources.length;
    const nextIdx = (currentIdx + 1) % videoSources.length;

    idleVideo.play();
    
    idleVideo.classList.replace('opacity-0', 'opacity-100');
    activeVideo.classList.replace('opacity-100', 'opacity-0');

    let temp = activeVideo;
    activeVideo = idleVideo;
    idleVideo = temp;

    setTimeout(() => {
        idleVideo.src = videoSources[nextIdx];
        idleVideo.load();
    }, 1000);

  }, 10000);
</script>
